# DevBridge — environment template
# Copy to .env and run scripts/check-ports.sh to populate ports

AGENT_PORT=3333
PWA_PORT=5173
RELAY_PORT=4444
RELAY_PUBLIC_URL=http://localhost:4444
RELAY_INTERNAL_URL=http://relay:4444

# JWT secret — 64 hex chars recommended
JWT_SECRET=change_me
RELAY_JWT_SECRET=

# VAPID keys for Web Push (run: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:devbridge@localhost

# Absolute path to expose to the agent's /files endpoint
PROJECT_ROOT=/home/user/projects

# ── Production (VPS) ─────────────────────────────────────────────────────────
# Set these in .env on the server (docker-compose.prod.yml)
#
# RELAY_PUBLIC_URL  = base URL of the relay API  (e.g. https://YOUR_DOMAIN/relay)
# RELAY_UI_URL      = base URL of the Nuxt UI    (e.g. https://YOUR_DOMAIN)
#                     Used to build QR codes — omit if relay and UI share the same domain root.
# NUXT_PUBLIC_RELAY_URL = same as RELAY_PUBLIC_URL
#
# Example (nginx proxies /relay/* → relay:4444, /* → ui:3000):
# RELAY_PUBLIC_URL=https://vibridge.clowerstudio.com/relay
# RELAY_UI_URL=https://vibridge.clowerstudio.com
# NUXT_PUBLIC_RELAY_URL=https://vibridge.clowerstudio.com/relay
#
# ── Local agent connecting to production relay ────────────────────────────────
# Set on the dev PC to use the prod relay instead of a local one:
# RELAY_INTERNAL_URL=https://YOUR_DOMAIN/relay
# RELAY_PUBLIC_URL=https://YOUR_DOMAIN/relay
