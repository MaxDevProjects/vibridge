# DevBridge — environment template
# Copy to .env and run scripts/check-ports.sh to populate ports

AGENT_PORT=3333
PWA_PORT=5173
RELAY_PORT=4444
RELAY_PUBLIC_URL=http://localhost:4444
RELAY_INTERNAL_URL=http://relay:4444

# JWT secret — 64 hex chars recommended
JWT_SECRET=change_me
RELAY_JWT_SECRET=

# VAPID keys for Web Push (run: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:devbridge@localhost

# Absolute path to expose to the agent's /files endpoint
PROJECT_ROOT=/home/user/projects

# ── Production (VPS) ─────────────────────────────────────────────────────────
# Set these in .env on the server (docker-compose.prod.yml)
# RELAY_PUBLIC_URL=https://YOUR_DOMAIN/relay
# NUXT_PUBLIC_RELAY_URL=https://YOUR_DOMAIN/relay
